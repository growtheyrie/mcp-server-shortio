# Configuration for Short.io MCP Server
# Make a copy of this file as .env and fill in your actual values

# Short.io API Key (required)
# Get this from https://app.short.io/settings/integrations/api-key
SHORTIO_API_KEY=your_api_key_here

# Default domain ID (optional but recommended)
# Get this from shortio_list_domains, or from your Short.io dashboard domain settings
SHORTIO_DOMAIN_ID=1493810

# Timezone (optional, defaults to Asia/Kuala_Lumpur)
# Used for all datetime conversions
TIMEZONE=Asia/Kuala_Lumpur

# Log level (optional, defaults to INFO)
# Available options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
